  document.querySelectorAll('.fbtn').forEach(function(b){ b.classList.remove('active-filter'); });
  var btnMap = {'all':'fAll','Benefits and Leave':'fBenefits','Compliance':'fCompliance','Employee Relations':'fER','Employee Support':'fES','HR Technology':'fTech','Onboarding':'fOnboarding','Payroll':'fPayroll','PEO':'fPEO'};
  var activeBtn = document.getElementById(btnMap[cat] || 'fAll');
  if(activeBtn) activeBtn.classList.add('active-filter');
  renderT();
}

function renderT() {
  var c = document.getElementById('t-items');
  c.innerHTML = '';
  var items = tFilter === 'all' ? tData : tData.filter(function(i){ return i.cat === tFilter; });
  items.forEach(function(item) {
    var idx = tData.indexOf(item);
    var ans = tAnswers[idx];
    var color = catColors[item.cat] || '#888';
    var d = document.createElement('div');
    d.style.cssText = 'background:var(--white);border:1px solid ' + (ans==='no'?'var(--orange)':ans==='yes'?'#2a9d8f':'var(--border)') + ';border-radius:12px;overflow:hidden;';
    d.innerHTML = '<div style="padding:1rem 1.25rem;">' +
      '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;">' +
        '<div style="flex:1;">' +
          '<span style="font-size:10px;letter-spacing:0.08em;text-transform:uppercase;font-weight:500;color:' + color + ';display:block;margin-bottom:4px;">' + item.cat + '</span>' +
          '<p style="font-size:14px;color:var(--text);line-height:1.6;margin:0;">' + item.q + '</p>' +
        '</div>' +
        '<div style="display:flex;gap:6px;flex-shrink:0;margin-top:2px;">' +
          '<button onclick="tSetAns(' + idx + ','yes')" style="padding:5px 16px;border-radius:6px;border:1px solid var(--border);font-size:13px;cursor:pointer;font-family:var(--sans);font-weight:500;background:' + (ans==='yes'?'#2a9d8f':'var(--white)') + ';color:' + (ans==='yes'?'#fff':'var(--text-mid)') + ';">Yes</button>' +
          '<button onclick="tSetAns(' + idx + ','no')" style="padding:5px 16px;border-radius:6px;border:1px solid var(--border);font-size:13px;cursor:pointer;font-family:var(--sans);font-weight:500;background:' + (ans==='no'?'var(--orange)':'var(--white)') + ';color:' + (ans==='no'?'#fff':'var(--text-mid)') + ';">No</button>' +
        '</div>' +
      '</div>' +
      (ans==='no'?'<div style="margin-top:10px;padding:10px 14px;background:var(--orange-light);border-top:1px solid #f5d4c5;"><span style="font-size:10px;letter-spacing:0.08em;text-transform:uppercase;font-weight:500;color:var(--orange);display:block;margin-bottom:3px;">How Melita helps</span><p style="font-size:13px;color:var(--text-mid);line-height:1.55;margin:0;">' + item.melita + '</p></div>':'') +
    '</div>';
    c.appendChild(d);
  });
  tUpdateSummary();
}

function tSetAns(idx, val) {
  tAnswers[idx] = tAnswers[idx] === val ? null : val;
  renderT();
}

function tUpdateSummary() {
  var answered = Object.keys(tAnswers).filter(function(k){ return tAnswers[k]; }).length;
  var nos = Object.keys(tAnswers).filter(function(k){ return tAnswers[k]==='no'; }).length;
  var sumEl = document.getElementById('t-summary');
  var bookBtn = document.getElementById('t-book-btn');
  if(answered === 0) { sumEl.style.display='none'; return; }
  sumEl.style.display='block';
  var txt = '';
  if(nos===0) txt = 'This client appears to have strong HR infrastructure in place. Melita may still add value as a strategic supplement or for specific tactical offload.';
  else if(nos<=3) txt = 'This client has ' + nos + ' gap' + (nos>1?'s':'') + ' where Melita can step in with targeted, modular support — a natural fit.';
  else if(nos<=7) txt = 'With ' + nos + ' gaps identified, this client has meaningful HR infrastructure needs. Melita can address these modularly, starting with the highest-priority areas.';
  else txt = 'This client has significant HR infrastructure gaps across ' + nos + ' areas. A broader Melita engagement could meaningfully transform their operations \u2014 worth a conversation.';
  document.getElementById('t-summary-text').textContent = txt;
  if(nos>=2) { bookBtn.style.display='inline-block'; } else { bookBtn.style.display='none'; }
}

renderT();

function showPage(pageId) {
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  var page = document.getElementById('page-' + pageId);
  var btn = document.querySelector('[data-page="' + pageId + '"]');
  if(page) { page.classList.add('active'); page.scrollTop=0; }
  if(btn) { btn.classList.add('active'); btn.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'}); }
}
</script>
